/ {
    /* Split input: forwards touchpad data from peripheral to central via BLE */
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        tps43_split: tps43_split@74 {
            compatible = "zmk,input-split";
            reg = <0x74>;
            device = <&tps43>;
        };
    };

    /* Remove display chosen so ZMK display subsystem won't compile */
    chosen {
        /delete-property/ zephyr,display;
    };
};

/* Disable OLED — frees I2C bus for the touchpad */
&oled {
    status = "disabled";
};

&pro_micro_i2c {
    status = "okay";

    tps43: iqs5xx@74 {
        compatible = "azoteq,iqs5xx";
        reg = <0x74>;

        /* No RDY pin — using polling mode (4 wires only: SDA, SCL, VCC, GND) */
        poll-interval-ms = <20>;

        one-finger-tap;
        press-and-hold;
        press-and-hold-time = <250>;
        two-finger-tap;

        scroll;
        natural-scroll-y;
        
        /*
         * Axis mapping — TPS65 length (65mm) mounted vertically.
         * Adjust these if axes are swapped or inverted after testing:
         *   flip-x;       ← invert horizontal
         *   flip-y;       ← invert vertical
         *   switch-xy;    ← swap X and Y axes
         */
        flip-x;
        flip-y;
        switch-xy;

        /* Tuning */
        bottom-beta = <3>;
        stationary-threshold = <3>;
    };
};
